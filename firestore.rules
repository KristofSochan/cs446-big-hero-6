rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- helpers ---

    function signedIn() {
      return request.auth != null;
    }

    function isStationOwner() {
      return signedIn() && request.auth.uid == resource.data.ownerId;
    }

    function ownerIdUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    // Non-owners may only touch queue/session fields at the top level (all other
    // fields — id, name, ownerId, config, etc. — are implicitly protected).
    function guestOnlyAllowedTopLevelKeys() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'attendees',
          'currentSession',
          'currentReservation'
        ]);
    }

    function attendeeMap(data) {
      return data.attendees != null ? data.attendees : {};
    }

    // Guests may only add/remove/reorder their own attendee entry (not others').
    function attendeesSelfOnlyDelta() {
      let before = attendeeMap(resource.data);
      let after = attendeeMap(request.resource.data);
      let d = after.diff(before);
      return (d.addedKeys().size() == 0 ||
          d.addedKeys().hasOnly([request.auth.uid])) &&
        (d.removedKeys().size() == 0 ||
          d.removedKeys().hasOnly([request.auth.uid])) &&
        (d.changedKeys().size() == 0 ||
          d.changedKeys().hasOnly([request.auth.uid]));
    }

    function sessionOkNonOwner() {
      let before = resource.data.currentSession;
      let after = request.resource.data.currentSession;
      return before == after ||
        (before == null && after != null && after.userId == request.auth.uid) ||
        (before != null && after == null && before.userId == request.auth.uid);
    }

    function reservationOkNonOwner() {
      let before = resource.data.currentReservation;
      let after = request.resource.data.currentReservation;
      return before == after ||
        (before != null && after == null && before.userId == request.auth.uid);
    }

    function guestSelfServiceUpdate() {
      return signedIn() &&
        guestOnlyAllowedTopLevelKeys() &&
        ownerIdUnchanged() &&
        attendeesSelfOnlyDelta() &&
        sessionOkNonOwner() &&
        reservationOkNonOwner();
    }

    // USERS
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update, delete: if signedIn() && request.auth.uid == userId;
    }

    // STATIONS
    function listOwnStationsQuery() {
      return signedIn() &&
            request.auth.uid == resource.data.ownerId;
    }

    match /stations/{stationId} {
      allow get: if true;
      allow list: if listOwnStationsQuery();

      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid;

      allow delete: if signedIn() &&
        request.auth.uid == resource.data.ownerId;

      allow update: if signedIn() &&
        ownerIdUnchanged() &&
        (
          isStationOwner() ||
          guestSelfServiceUpdate()
        );
    }

    // Analytics (written only by Cloud Functions / Admin SDK)
    match /stationAnalytics/{stationId}/daily/{dayId} {
      allow read: if signedIn() &&
        get(/databases/$(database)/documents/stations/$(stationId))
          .data.ownerId == request.auth.uid;
      allow write: if false;
    }
  }
}

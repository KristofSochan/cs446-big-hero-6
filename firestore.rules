rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isStationOwner(stationId) {
      return signedIn() &&
        get(/databases/$(database)/documents/stations/$(stationId)).data.ownerId == request.auth.uid;
    }

    function ownerIdUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    function guestOnlyAllowedTopLevelKeys() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'attendees',
          'currentSession',
          'currentReservation'
        ]);
    }

    function attendeeMap(data) {
      return data.attendees != null ? data.attendees : {};
    }

    function attendeesSelfOnlyDelta() {
      let before = attendeeMap(resource.data);
      let after = attendeeMap(request.resource.data);
      let d = after.diff(before);
      let uid = request.auth.uid;
      return (d.addedKeys().size() == 0 || d.addedKeys().hasOnly([uid])) &&
        (d.removedKeys().size() == 0 || d.removedKeys().hasOnly([uid])) &&
        d.changedKeys().size() == 0;
    }

    function currentSessionOrNull(data) {
      return data.keys().hasAny(['currentSession']) ? data.currentSession : null;
    }

    function currentReservationOrNull(data) {
      return data.keys().hasAny(['currentReservation']) ? data.currentReservation : null;
    }

    function sessionOkNonOwner() {
      let before = currentSessionOrNull(resource.data);
      let after = currentSessionOrNull(request.resource.data);
      let operatorOnly = resource.data.operatorManagesSessionsOnly == true;

      return before == after ||
        (!operatorOnly &&
          before == null &&
          after != null &&
          after.userId == request.auth.uid &&
          after.keys().hasOnly(['userId'])) ||
        (!operatorOnly &&
          before != null &&
          after == null &&
          before.userId == request.auth.uid);
    }

    function reservationOkNonOwner() {
      let before = currentReservationOrNull(resource.data);
      let after = currentReservationOrNull(request.resource.data);

      return before == after ||
        (before != null &&
          after == null &&
          before.userId == request.auth.uid);
    }

    function guestSelfServiceUpdate() {
      return signedIn() &&
        guestOnlyAllowedTopLevelKeys() &&
        ownerIdUnchanged() &&
        attendeesSelfOnlyDelta() &&
        sessionOkNonOwner() &&
        reservationOkNonOwner();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update, delete: if signedIn() && request.auth.uid == userId;
    }

    function listOwnStationsQuery() {
      return signedIn() &&
        request.auth.uid == resource.data.ownerId;
    }

    match /stations/{stationId} {
      allow get: if true;
      allow list: if listOwnStationsQuery();

      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid;

      allow delete: if signedIn() &&
        request.auth.uid == resource.data.ownerId;

      allow update: if signedIn() &&
        ownerIdUnchanged() &&
        (
          signedIn() && request.auth.uid == resource.data.ownerId ||
          guestSelfServiceUpdate()
        );
    }

    match /stationAnalytics/{stationId} {
      // Allow any signed-in user to read history so guests can see predicted wait times
      allow read: if signedIn();

      allow create: if signedIn() &&
        get(/databases/$(database)/documents/stations/$(stationId)).data.ownerId == request.auth.uid;

      allow update: if signedIn();

      match /daily/{dayId} {
        allow read: if signedIn();
        allow write: if false;
      }
    }
  }
}
